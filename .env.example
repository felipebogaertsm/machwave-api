# Local development defaults to the dev environment

# GCP / Firebase
GCP_PROJECT_ID=machwave

GCS_BUCKET_NAME=machwave-data-dev

# Firebase project ID — separate project per environment
FIREBASE_PROJECT_ID=machwave-dev

# Cloud Run Jobs
CLOUD_RUN_JOB_NAME=machwave-worker-dev
CLOUD_RUN_JOB_REGION=us-central1

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# Local development — path to a GCP service account key file
# On Cloud Run, application-default credentials are used automatically
GOOGLE_APPLICATION_CREDENTIALS=./sa-key.json
