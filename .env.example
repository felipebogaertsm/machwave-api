# Local development defaults to the dev environment

# Selects the simulation runner: "local" spawns the worker as a subprocess
ENV=local

# GCP / Firebase
GCP_PROJECT_ID=machwave

GCS_BUCKET_NAME=machwave-data-dev

# Firebase project ID — separate project per environment
FIREBASE_PROJECT_ID=machwave-dev

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000
